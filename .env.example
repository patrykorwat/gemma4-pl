# Copy this file to `.env` and fill in your values. `.env` is gitignored.

# HuggingFace token with gated access to google/gemma-4-E4B
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Weights and Biases
WANDB_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WANDB_PROJECT=gemma4-pl
WANDB_ENTITY=your-team

# PLGrid grant identifier used for SLURM -A flag
PLG_GRANT=plgbielikr2026

# Paths on Helios ($SCRATCH and $PLG_GROUPS_STORAGE resolve at login time,
# values here are defaults if those env vars are unset)
BIELIK_R_SCRATCH=/net/scratch/people/plgYOURUSER/bielik-r
BIELIK_R_CACHE=/net/scratch/people/plgYOURUSER/bielik-r/cache
BIELIK_R_MODELS=/net/scratch/people/plgYOURUSER/bielik-r/models
BIELIK_R_DATA=/net/scratch/people/plgYOURUSER/bielik-r/data
BIELIK_R_CHECKPOINTS=/net/scratch/people/plgYOURUSER/bielik-r/checkpoints

# Base model repo on HuggingFace
BASE_MODEL=google/gemma-4-E4B
