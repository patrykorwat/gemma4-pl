# Copy this file to `.env` and fill in your values. `.env` is gitignored.

# HuggingFace token with gated access to google/gemma-4-E4B
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Weights and Biases
WANDB_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WANDB_PROJECT=gemma4-pl
WANDB_ENTITY=your-team

# Base model repo on HuggingFace
BASE_MODEL=google/gemma-4-E4B

# Paths on the cluster. $SCRATCH is resolved at login time on most HPC
# sites, the values below are fallback defaults if it is not set.
GEMMA4_PL_ROOT=/scratch/${USER}/gemma4-pl
GEMMA4_PL_CACHE=/scratch/${USER}/gemma4-pl/cache
GEMMA4_PL_MODELS=/scratch/${USER}/gemma4-pl/models
GEMMA4_PL_DATA=/scratch/${USER}/gemma4-pl/data
GEMMA4_PL_CHECKPOINTS=/scratch/${USER}/gemma4-pl/checkpoints
